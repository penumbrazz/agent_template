# =============================================================================
# Agent Template - Root .env
# =============================================================================
# Copy this file to .env and customize as needed.
#   cp .env.example .env
#
# This file controls variables read by docker-compose.yml / docker-compose.dev.yml.
# Per-service config still lives in:
#   backend/.env  — secrets, langfuse, sentry, etc.
#   frontend/.env — API URL, sentry DSN, etc.
#
# ⚠️  All values below are PLACEHOLDERS for local development only.
#     Replace every secret before deploying to any non-local environment.
# =============================================================================


# -----------------------------------------------------------------------------
# Shared (used by docker-compose to wire backend <-> postgres/redis)
# -----------------------------------------------------------------------------
# Host ports exposed on the Docker host. Override only if you have conflicts.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# PostgreSQL credentials. Backend resolves the container by service name
# ("postgres"), so the host portion of DATABASE_URL is fixed inside compose;
# these values only need to match between compose and the database volume.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_template
# Dev-only: localhost port mapping for external DB clients (dev compose).
# POSTGRES_PORT=5432

# Redis. The backend connects to the "redis" service internally; this is only
# used by the dev compose to expose Redis on localhost for debugging.
# REDIS_PORT=6379


# -----------------------------------------------------------------------------
# Backend (mirrors backend/.env.example for convenience)
# -----------------------------------------------------------------------------
# Full SQLAlchemy URL. In docker compose this is assembled automatically from
# POSTGRES_* above; set this only when running the backend outside compose.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/agent_template

# Redis URL. Override only when running the backend outside compose.
# REDIS_URL=redis://localhost:6379/0

# JWT signing secret. MUST be a long random string in any non-dev environment.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# AES/Fernet symmetric key used to encrypt provider credentials at rest.
# MUST be exactly 32 bytes, urlsafe-base64-encoded is NOT required — the raw
# 32-char ASCII key below is the Fernet-compatible form. Replace before deploy.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-32-byte-key-replace-me

# Runtime environment. Anything other than "development" enforces strong
# SECRET_KEY / ENCRYPTION_KEY validation at startup.
ENVIRONMENT=development


# -----------------------------------------------------------------------------
# OpenTelemetry (optional, shared)
# -----------------------------------------------------------------------------
# OTel is DISABLED by default. Enabling it requires the telemetry stack:
#   cd telemetry && docker compose up -d
# The backend will not crash when OTel is disabled, even though the default
# OTEL_EXPORTER_OTLP_ENDPOINT points at a not-yet-running collector.
OTEL_ENABLED=false
# gRPC endpoint used by the backend to export spans/metrics.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# HTTP endpoint used by the browser (Next.js) SDK. Must be reachable from
# the user's browser, hence localhost rather than the internal service name.
NEXT_PUBLIC_OTEL_COLLECTOR_ENDPOINT=http://localhost:4318
