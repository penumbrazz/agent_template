# Agent Template Configuration
# Copy this file to .env and customize as needed
# Usage: cp .env.example .env

# =============================================================================
# POSTGRESQL
# =============================================================================

# DATABASE_URL=postgresql+psycopg2://postgres:your-password@localhost:5432/agent_template

# =============================================================================
# REDIS
# =============================================================================

# REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# BACKEND
# =============================================================================

BACKEND_PORT=8000
# BACKEND_SECRET_KEY=your-secret-key-here
# BACKEND_ALGORITHM=HS256
# BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =============================================================================
# FRONTEND
# =============================================================================

FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# OPENTELEMETRY - Backend (optional)
# =============================================================================

OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# LANGFUSE (LLM Observability)
# =============================================================================

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=http://localhost:3000

# =============================================================================
# GLITCHTIP / SENTRY (Error Tracking)
# =============================================================================

# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=  (also in frontend/.env for local dev)

# =============================================================================
# OPENTELEMETRY - Frontend (optional)
# =============================================================================

NEXT_PUBLIC_OTEL_ENABLED=false
# NEXT_PUBLIC_OTEL_SERVICE_NAME=agent-template-frontend
# NEXT_PUBLIC_OTEL_COLLECTOR_ENDPOINT=http://localhost:4318
# NEXT_PUBLIC_APP_VERSION=dev
