# Agent Template Configuration
# Copy this file to .env and customize as needed
# Usage: cp .env.example .env

# =============================================================================
# MYSQL
# =============================================================================

MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=agent_template
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
# MYSQL_PORT=3306

# =============================================================================
# REDIS
# =============================================================================

# REDIS_PORT=6379

# =============================================================================
# BACKEND
# =============================================================================

BACKEND_PORT=8000
# BACKEND_SECRET_KEY=your-secret-key-here
# BACKEND_ALGORITHM=HS256
# BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =============================================================================
# FRONTEND
# =============================================================================

FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# OPENTELEMETRY (optional)
# =============================================================================

OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
NEXT_PUBLIC_OTEL_ENABLED=false
# NEXT_PUBLIC_OTEL_SERVICE_NAME=agent-template-frontend
# NEXT_PUBLIC_OTEL_COLLECTOR_ENDPOINT=http://localhost:4318
# NEXT_PUBLIC_APP_VERSION=dev
